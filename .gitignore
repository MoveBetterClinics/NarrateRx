node_modules
dist
.env
.env.local
.DS_Store

# Generated at build time by scripts/write-version.mjs
public/version.json

# Per-developer Claude Code permission state — local-only by convention
.claude/settings.local.json

# Claude Code cowork session worktrees — local-only
.claude/worktrees/

# Claude Code scheduled-task runtime artifacts — local-only
.claude/scheduled_tasks.lock
.vercel
.env*.local
.env.local.1pw

# Playwright
test-results/
playwright-report/
tests/e2e/.auth/

# Local-only design mockups + audit baselines (per-developer working files)
.claude/mockups/
.claude/audit-history/

# Local test/sample media (recordings, screenshots, zips used in dev sessions)
data/
_voice-samples/

# Python bytecode cache (from scripts/*.py)
__pycache__/
*.pyc
